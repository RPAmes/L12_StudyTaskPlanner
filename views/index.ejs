<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <title>Home | Study Task Planner</title>
</head>

<body>
    <%- include ('partials/navbar.ejs') %>
        <div class="container mt-4">

            <div class="d-flex justify-content-between align-items-center mb-3">
                <h2 class="fw-bold">Study Task Planner</h2>
                <a href="/tasks" class="btn btn-success">+ Add Task</a>
            </div>

            <form action="/" method="GET" class="mb-3">
                <div class="input-group shadow-sm">
                    <input type="text" class="form-control" placeholder="Search by task name or priority" name="search"
                        value="<%= search %>">
                    <button type="submit" class="btn btn-primary">Search</button>
                    <a href="/" class="btn btn-outline-secondary">Clear</a>
                </div>
            </form>


            <div class="card shadow-sm">
                <div class="card-body">
                    <table class="table table-hover align-middle">
                        <thead class="table-dark">
                            <tr>
                                <th>ID</th>
                                <th>Task Name</th>
                                <th>Deadline</th>
                                <th>Priority</th>
                                <th>Notes</th>
                                <th>Edit</th>
                                <th>Delete</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% for (let i=0; i < tasks.length; i++) { %>
                                <tr>
                                    <td>
                                        <%= tasks[i].id %>
                                    </td>
                                    <td>
                                        <a href="/tasks/<%= tasks[i].id %>" class="fw-semibold text-decoration-none">
                                            <%= tasks[i].taskName %>
                                        </a>
                                    </td>
                                    <td>
                                        <%= tasks[i].deadline %>
                                    </td>
                                    <td>
                                        <% if (tasks[i].priority==="High" ) { %>
                                            <span class="badge bg-danger">
                                                <%= tasks[i].priority %>
                                            </span>
                                            <% } else if (tasks[i].priority==="Medium" ) { %>
                                                <span class="badge bg-warning text-dark">
                                                    <%= tasks[i].priority %>
                                                </span>
                                                <% } else { %>
                                                    <span class="badge bg-success">
                                                        <%= tasks[i].priority %>
                                                    </span>
                                                    <% } %>
                                    </td>
                                    <td>
                                        <%= tasks[i].notes %>
                                    </td>
                                    <td>
                                        <a href="/tasks/<%= tasks[i].id %>/update"
                                            class="btn btn-sm btn-warning">Edit</a>
                                    </td>
                                    <td>
                                        <a href="/tasks/<%= tasks[i].id %>/delete"
                                            class="btn btn-sm btn-danger">Delete</a>
                                    </td>
                                </tr>
                                <% } %>
                        </tbody>
                    </table>
                </div>
            </div>

        </div>
</body>

</html>