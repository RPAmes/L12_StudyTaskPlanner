<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <title>Task Details | Study Task Planner</title>
</head>
<body>
    <%- include ('partials/navbar.ejs') %>
        <div class="container mt-4">
            <h2 class="mb-4 fw-bold">Task Details</h2>
            <div class="card shadow-sm">
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Task Name:</label>
                        <div class="form-control bg-light">
                            <%= task.taskName %>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Deadline:</label>
                        <div class="form-control bg-light">
                            <%= task.deadline %>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Priority:</label>
                        <div class="form-control bg-light">
                            <% if (task.priority==="High" ) { %>
                                <span class="badge bg-danger">
                                    <%= task.priority %>
                                </span>
                                <% } else if (task.priority==="Medium" ) { %>
                                    <span class="badge bg-warning text-dark">
                                        <%= task.priority %>
                                    </span>
                                    <% } else { %>
                                        <span class="badge bg-success">
                                            <%= task.priority %>
                                        </span>
                                        <% } %>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Notes:</label>
                        <div class="form-control bg-light">
                            <%= task.notes %>
                        </div>
                    </div>

                    <div class="text-center">
                        <a href="/tasks/<%= task.id %>/update" class="btn btn-warning">Edit Task</a>
                        <a href="/tasks/<%= task.id %>/delete" class="btn btn-danger">Delete Task</a>
                        <a href="/" class="btn btn-secondary">Back Home</a>
                    </div>
                </div>
            </div>
        </div>
</body>
</html>